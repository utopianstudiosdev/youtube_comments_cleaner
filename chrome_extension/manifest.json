{
  "manifest_version": 3,
  "name": "YouTube Comments Cleaner",
  "version": "1.0",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "description": "Clean your YouTube comment history",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": ["https://myactivity.google.com/*"],
  "action": {
    "default_popup": "popup.html",
	"default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://myactivity.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
